@page
@model SetPasswordModel
@{
    ViewData["Title"] = "Legacy launcher password";
    ViewData["ActivePage"] = ManageNavPages.SetPassword;
}

<h4>@ViewData["Title"]</h4>
<partial name="_StatusMessage" for="StatusMessage" />
<p class="text-info">
    This is a temporary password for logging into the old launcher.
    It changes every 2 minutes. Use the code below as your password.
</p>

<div class="row">
    <div class="col-md-6">
        <div id="totp-container" class="text-center">
            <div class="d-inline-block position-relative mb-3">
                <svg width="160" height="160" viewBox="0 0 160 160">
                    <circle cx="80" cy="80" r="70" fill="none" stroke="#383845" stroke-width="8" />
                    <circle id="progress-ring" cx="80" cy="80" r="70" fill="none" stroke="#1b6ec2" stroke-width="8"
                            stroke-linecap="round"
                            stroke-dasharray="439.8"
                            stroke-dashoffset="0"
                            transform="rotate(-90, 80, 80)" />
                </svg>
                <div id="totp-code" class="monotype position-absolute" style="top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 2rem; letter-spacing: 4px; color: #5e92d0;">
                    @Model.CurrentCode
                </div>
            </div>
            <p class="text-muted small">
                Code expires in <span id="remaining-seconds">@Model.RemainingSeconds</span> seconds
            </p>
            <form method="post" asp-page-handler="Regenerate" class="mt-2">
                <button type="submit" class="btn btn-outline-secondary">Generate new secret</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var totalInterval = @Model.RemainingSeconds;
            var remaining = totalInterval;
            var period = 120;
            var codeEl = document.getElementById('totp-code');
            var ringEl = document.getElementById('progress-ring');
            var remainingEl = document.getElementById('remaining-seconds');
            var circumference = 439.8;

            function refreshCode() {
                remaining = period;
                fetch('@Url.Page("SetPassword", "RefreshCode")', { credentials: 'same-origin' })
                    .then(function(r) {
                        if (!r.ok) throw new Error(r.status);
                        return r.text();
                    })
                    .then(function(code) {
                        if (code && code.length <= 10) {
                            codeEl.textContent = code;
                        } else {
                            location.reload();
                        }
                    })
                    .catch(function() {
                        location.reload();
                    });
            }

            function updateTimer() {
                remaining--;
                if (remaining <= 0) {
                    refreshCode();
                }
                var offset = circumference * (1 - remaining / period);
                ringEl.setAttribute('stroke-dashoffset', offset);
                remainingEl.textContent = remaining;
            }

            updateTimer();
            setInterval(updateTimer, 1000);
        })();
    </script>
}
