@page
@model SS14.Web.Pages.LauncherSSOModel
@{
    ViewData["Title"] = "Launcher Login";
}

<div class="text-center" style="margin-top: 60px;">
    <h1 class="display-4">Launcher Login</h1>
    <p class="lead">Choose how to sign in to the launcher</p>

    @if (!string.IsNullOrEmpty(Model.SsoCode))
    {
        <div style="margin-top: 30px; padding: 20px; background: #e8f5e9; border-radius: 8px; max-width: 400px; margin-left: auto; margin-right: auto;">
            <h3>Login Successful!</h3>
            <p>Enter this code in the launcher:</p>
            <div style="font-size: 24px; font-weight: bold; letter-spacing: 4px; padding: 10px; background: white; border-radius: 4px; border: 1px solid #ccc; font-family: monospace;">
                @Model.SsoCode
            </div>
            <p style="margin-top: 16px; font-size: 12px; color: #666;">This code expires in 5 minutes.</p>
        </div>
    }
    else if (Model.ShowProviderButtons)
    {
        <div style="margin-top: 30px; display: flex; flex-direction: column; align-items: center; gap: 12px;">
            @foreach (var provider in Model.ExternalLogins)
            {
                <form asp-page="./LauncherSSO" asp-page-handler="ExternalLogin" method="post" style="width: 100%; max-width: 300px;">
                    <input type="hidden" name="provider" value="@provider.Name" />
                    <button type="submit" style="width: 100%; padding: 12px 24px; font-size: 16px; border: 1px solid #ccc; border-radius: 6px; background: white; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;">
                        Sign in with @provider.DisplayName
                    </button>
                </form>
            }
        </div>
    }
    else
    {
        <p style="margin-top: 20px; color: #666;">Loading...</p>
    }
</div>
